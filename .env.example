NEXT_PUBLIC_APP_NAME="Vote OSS"
NEXT_PUBLIC_APP_URL=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vote_oss?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=your-access-secret-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-here

# Encrypts election private keys in database
# 64 chars, hex format
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATABASE_ENCRYPTION_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

CAMPUS_API_URL=http://localhost:3001
CAMPUS_INTEGRATION_API_KEY=your-integration-secret

# KPI ID Auth
NEXT_PUBLIC_KPI_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_KPI_APP_ID=your-app-id
KPI_APP_SECRET=your-kpi-app-secret

CRON_SECRET=your-cron-secret-min-32-chars-here

# For ip rate limit
TRUSTED_PROXY_COUNT=1

# External KPI docs generator used to render protocol PDFs.  Both fields have
# sensible defaults pointing at the public hosted instance; override them for
# self-hosting or for using a different document template.
# PROTOCOL_GENERATOR_URL=https://kpi-docs-generator.onrender.com/api
# PROTOCOL_TEMPLATE_ID=1uRjSw17KziQQsomG8I30tvrnEv0PjM2pcDkVNwzcijw

# MinIO object storage used for uploaded images (group logos, etc.).
# The public bucket must be readable over the public internet — both browsers
# and the external docs generator fetch image URLs straight from MinIO.
MINIO_ENDPOINT=212.111.193.238
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PUBLIC_BUCKET=kpistats-public
# Optional override for the public URL base (no trailing slash).  When unset
# we build it from MINIO_USE_SSL/MINIO_ENDPOINT/MINIO_PORT.
# MINIO_PUBLIC_URL_BASE=https://files.example.com
