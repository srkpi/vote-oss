generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model JwtToken {
  access_jti      String   @unique
  refresh_jti     String   @unique
  created_at      DateTime @default(now())
  initial_auth_at DateTime @default(now())

  @@index([created_at])
  @@map("jwt_tokens")
}

model Admin {
  user_id               String    @id
  full_name             String
  group                 String
  faculty               String
  promoted_by           String?
  promoter              Admin?    @relation("AdminHierarchy", fields: [promoted_by], references: [user_id], onDelete: Restrict)
  subordinates          Admin[]   @relation("AdminHierarchy")
  promoted_at           DateTime  @default(now())
  manage_admins         Boolean   @default(false)
  manage_groups         Boolean   @default(false)
  restricted_to_faculty Boolean   @default(true)
  deleted_at            DateTime?
  deleted_by            String?

  created_elections              Election[]
  deleted_elections              Election[]             @relation("ElectionDeleter")
  created_invite_tokens          AdminInviteToken[]
  created_global_bypass_tokens   GlobalBypassToken[]
  deleted_global_bypass_tokens   GlobalBypassToken[]    @relation("GlobalBypassTokenDeleter")
  created_election_bypass_tokens ElectionBypassToken[]
  deleted_election_bypass_tokens ElectionBypassToken[]  @relation("ElectionBypassTokenDeleter")

  revoked_global_bypass_tokens_usages   GlobalBypassTokenUsage[]    @relation("GlobalBypassTokenUsageRevoker")
  revoked_election_bypass_tokens_usages ElectionBypassTokenUsage[]  @relation("ElectionBypassTokenUsageRevoker")

  created_faq_categories FaqCategory[] @relation("FaqCategoryCreator")
  updated_faq_categories FaqCategory[] @relation("FaqCategoryUpdater")
  created_faq_items      FaqItem[]     @relation("FaqItemCreator")
  updated_faq_items      FaqItem[]     @relation("FaqItemUpdater")

  @@index([promoted_by])
  @@map("admins")
}

model AdminInviteToken {
  token_hash            String   @id
  max_usage             Int
  current_usage         Int      @default(0)
  manage_admins         Boolean  @default(false)
  manage_groups         Boolean  @default(false)
  restricted_to_faculty Boolean  @default(true)
  valid_due             DateTime
  created_at            DateTime @default(now())
  created_by            String
  creator               Admin    @relation(fields: [created_by], references: [user_id], onDelete: Cascade)

  @@index([created_by])
  @@map("admin_invite_tokens")
}

model Election {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  created_by    String
  creator       Admin    @relation(fields: [created_by], references: [user_id], onDelete: Restrict)
  created_at    DateTime @default(now())
  opens_at      DateTime
  closes_at     DateTime

  min_choices     Int     @default(1)
  max_choices     Int     @default(1)
  shuffle_choices Boolean @default(false)
  public_viewing  Boolean @default(false)
  anonymous       Boolean @default(true)

  restrictions  ElectionRestriction[]
  winning_conditions Json @default("{}")

  public_key    String @db.Text
  private_key   String @db.Text

  deleted_at    DateTime?
  deleted_by    String?

  choices                ElectionChoice[]
  issued_tokens          IssuedToken[]
  ballots                Ballot[]
  nullifiers             UsedTokenNullifier[]
  deleter                Admin?              @relation("ElectionDeleter", fields: [deleted_by], references: [user_id], onDelete: SetNull)
  election_bypass_tokens ElectionBypassToken[]

  @@map("elections")
}

enum RestrictionType {
  FACULTY
  GROUP
  SPECIALITY
  STUDY_YEAR
  STUDY_FORM
  LEVEL_COURSE
  BYPASS_REQUIRED
  GROUP_MEMBERSHIP
}

model ElectionRestriction {
  id          String          @id @default(uuid()) @db.Uuid
  election_id String          @db.Uuid
  election    Election        @relation(fields: [election_id], references: [id], onDelete: Cascade)
  type        RestrictionType
  value       String

  @@index([election_id, type])
  @@map("election_restrictions")
}

model ElectionChoice {
  id          String   @id @default(uuid()) @db.Uuid
  election_id String   @db.Uuid
  election    Election @relation(fields: [election_id], references: [id], onDelete: Cascade)
  choice      String
  position    Int
  vote_count  Int?

  @@index([election_id, position])
  @@map("election_choices")
}

model IssuedToken {
  id          String   @id @default(uuid()) @db.Uuid
  election_id String   @db.Uuid
  election    Election @relation(fields: [election_id], references: [id], onDelete: Cascade)
  user_id     String

  @@unique([election_id, user_id])
  @@map("issued_tokens")
}

model Ballot {
  id               String   @id @default(uuid()) @db.Uuid
  election_id      String   @db.Uuid
  election         Election @relation(fields: [election_id], references: [id], onDelete: Cascade)
  encrypted_ballot String   @unique @db.Text
  created_at       DateTime @default(now())
  signature        String   @db.Text
  previous_hash    String?
  current_hash     String   @unique

  @@index([election_id])
  @@map("ballots")
}

model UsedTokenNullifier {
  nullifier   String   @id
  election_id String   @db.Uuid
  election    Election @relation(fields: [election_id], references: [id], onDelete: Cascade)

  @@index([election_id])
  @@map("used_token_nullifiers")
}

model GlobalBypassToken {
  token_hash          String    @id
  bypass_not_studying Boolean   @default(false)
  bypass_graduate     Boolean   @default(false)
  max_usage           Int
  current_usage       Int       @default(0)
  valid_until         DateTime
  created_by          String
  creator             Admin     @relation(fields: [created_by], references: [user_id], onDelete: Restrict)
  created_at          DateTime  @default(now())
  deleted_at          DateTime?
  deleted_by          String?

  deleter             Admin?    @relation("GlobalBypassTokenDeleter", fields: [deleted_by], references: [user_id], onDelete: SetNull)
  usages              GlobalBypassTokenUsage[]

  @@index([created_by])
  @@map("global_bypass_tokens")
}

model GlobalBypassTokenUsage {
  id         String            @id @default(uuid()) @db.Uuid
  token_hash String
  token      GlobalBypassToken @relation(fields: [token_hash], references: [token_hash], onDelete: Cascade)
  user_id    String
  used_at    DateTime          @default(now())
  revoked_at DateTime?
  revoked_by String?
  revoker    Admin?            @relation("GlobalBypassTokenUsageRevoker", fields: [revoked_by], references: [user_id], onDelete: SetNull)

  @@unique([token_hash, user_id])
  @@index([user_id])
  @@map("global_bypass_token_usages")
}

model ElectionBypassToken {
  token_hash          String    @id
  election_id         String    @db.Uuid
  election            Election  @relation(fields: [election_id], references: [id], onDelete: Cascade)
  bypass_restrictions String[]
  max_usage           Int
  current_usage       Int       @default(0)
  created_by          String
  creator             Admin     @relation(fields: [created_by], references: [user_id], onDelete: Restrict)
  created_at          DateTime  @default(now())
  deleted_at          DateTime?
  deleted_by          String?

  deleter             Admin?    @relation("ElectionBypassTokenDeleter", fields: [deleted_by], references: [user_id], onDelete: SetNull)
  usages              ElectionBypassTokenUsage[]

  @@index([election_id])
  @@index([created_by])
  @@map("election_bypass_tokens")
}

model ElectionBypassTokenUsage {
  id         String              @id @default(uuid()) @db.Uuid
  token_hash String
  token      ElectionBypassToken @relation(fields: [token_hash], references: [token_hash], onDelete: Cascade)
  user_id    String
  used_at    DateTime            @default(now())
  revoked_at DateTime?
  revoked_by String?
  revoker    Admin?              @relation("ElectionBypassTokenUsageRevoker", fields: [revoked_by], references: [user_id], onDelete: SetNull)

  @@unique([token_hash, user_id])
  @@index([user_id])
  @@map("election_bypass_token_usages")
}

model FaqCategory {
  id         String   @id @default(uuid()) @db.Uuid
  title      String
  position   Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  created_by String
  updated_by String?
  creator    Admin    @relation("FaqCategoryCreator", fields: [created_by], references: [user_id], onDelete: Restrict)
  updater    Admin?   @relation("FaqCategoryUpdater", fields: [updated_by], references: [user_id], onDelete: Restrict)

  items FaqItem[]

  @@index([position])
  @@map("faq_categories")
}

model FaqItem {
  id          String      @id @default(uuid()) @db.Uuid
  category_id String      @db.Uuid
  category    FaqCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  title       String
  content     String      @db.Text
  position    Int
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  created_by  String
  updated_by  String?
  creator     Admin       @relation("FaqItemCreator", fields: [created_by], references: [user_id], onDelete: Restrict)
  updater     Admin?      @relation("FaqItemUpdater", fields: [updated_by], references: [user_id], onDelete: Restrict)

  @@index([category_id, position])
  @@map("faq_items")
}

model Group {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  owner_id   String
  created_by String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  updated_by String?
  deleted_at DateTime?
  deleted_by String?

  members      GroupMember[]
  invite_links GroupInviteLink[]

  @@index([owner_id])
  @@map("groups")
}

model GroupMember {
  id           String    @id @default(uuid()) @db.Uuid
  group_id     String    @db.Uuid
  group        Group     @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user_id      String
  display_name String
  joined_at    DateTime  @default(now())
  deleted_at   DateTime?
  deleted_by   String?

  @@unique([group_id, user_id])
  @@index([user_id])
  @@map("group_members")
}

model GroupInviteLink {
  id            String    @id @default(uuid()) @db.Uuid
  group_id      String    @db.Uuid
  group         Group     @relation(fields: [group_id], references: [id], onDelete: Cascade)
  token_hash    String    @unique
  label         String?
  max_usage     Int
  current_usage Int       @default(0)
  expires_at    DateTime
  created_by    String
  created_at    DateTime  @default(now())
  deleted_at    DateTime?
  deleted_by    String?

  usages GroupInviteLinkUsage[]

  @@index([group_id])
  @@map("group_invite_links")
}

model GroupInviteLinkUsage {
  id      String          @id @default(uuid()) @db.Uuid
  link_id String          @db.Uuid
  link    GroupInviteLink @relation(fields: [link_id], references: [id], onDelete: Cascade)
  user_id String
  used_at DateTime        @default(now())

  @@unique([link_id, user_id])
  @@index([user_id])
  @@map("group_invite_link_usages")
}
