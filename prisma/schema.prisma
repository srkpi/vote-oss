generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model JwtToken {
  access_jti  String   @unique
  refresh_jti String   @unique
  created_at  DateTime @default(now())

  @@index([created_at])
  @@map("jwt_tokens")
}

model Admin {
  user_id               String    @id
  full_name             String
  group                 String
  faculty               String
  promoted_by           String?
  promoter              Admin?    @relation("AdminHierarchy", fields: [promoted_by], references: [user_id], onDelete: Restrict)
  subordinates          Admin[]   @relation("AdminHierarchy")
  promoted_at           DateTime  @default(now())
  manage_admins         Boolean   @default(false)
  restricted_to_faculty Boolean   @default(true)
  deleted_at            DateTime?
  deleted_by            String?

  created_elections     Election[]
  created_invite_tokens AdminInviteToken[]

  created_faq_categories FaqCategory[] @relation("FaqCategoryCreator")
  updated_faq_categories FaqCategory[] @relation("FaqCategoryUpdater")
  created_faq_items      FaqItem[]     @relation("FaqItemCreator")
  updated_faq_items      FaqItem[]     @relation("FaqItemUpdater")

  @@map("admins")
}

model AdminInviteToken {
  token_hash            String   @id
  max_usage             Int
  current_usage         Int      @default(0)
  manage_admins         Boolean
  restricted_to_faculty Boolean
  valid_due             DateTime
  created_at            DateTime @default(now())
  created_by            String
  creator               Admin    @relation(fields: [created_by], references: [user_id], onDelete: Cascade)

  @@index([created_by])
  @@map("admin_invite_tokens")
}

model Election {
  id                    String   @id @default(uuid())
  title                 String
  created_by            String
  creator               Admin    @relation(fields: [created_by], references: [user_id], onDelete: Restrict)
  created_at            DateTime @default(now())
  opens_at              DateTime
  closes_at             DateTime
  restricted_to_faculty String?
  restricted_to_group   String?
  public_key            String   @db.Text
  private_key           String   @db.Text

  choices       ElectionChoice[]
  issued_tokens IssuedToken[]
  ballots       Ballot[]
  tallies       ElectionTally[]
  nullifiers    UsedTokenNullifier[]

  @@map("elections")
}

model ElectionChoice {
  id          String   @id @default(uuid())
  election_id String
  election    Election @relation(fields: [election_id], references: [id], onDelete: Cascade)
  choice      String
  position    Int

  tallies ElectionTally[]

  @@index([election_id, position])
  @@map("election_choices")
}

model IssuedToken {
  id          String   @id @default(uuid())
  election_id String
  election    Election @relation(fields: [election_id], references: [id], onDelete: Cascade)
  user_id     String

  @@unique([election_id, user_id])
  @@map("issued_tokens")
}

model Ballot {
  id               String   @id @default(uuid())
  election_id      String
  election         Election @relation(fields: [election_id], references: [id], onDelete: Cascade)
  encrypted_ballot String   @unique @db.Text
  created_at       DateTime @default(now())
  signature        String   @db.Text
  previous_hash    String?
  current_hash     String   @unique

  @@index([election_id])
  @@map("ballots")
}

model UsedTokenNullifier {
  nullifier   String   @id
  election_id String
  election    Election @relation(fields: [election_id], references: [id], onDelete: Cascade)

  @@index([election_id])
  @@map("used_token_nullifiers")
}

model ElectionTally {
  election_id String
  choice_id   String
  election    Election       @relation(fields: [election_id], references: [id], onDelete: Cascade)
  choice      ElectionChoice @relation(fields: [choice_id], references: [id], onDelete: Cascade)
  vote_count  Int

  @@id([election_id, choice_id])
  @@map("election_tallies")
}

model FaqCategory {
  id         String   @id @default(uuid())
  title      String
  position   Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  created_by String
  updated_by String?
  creator    Admin    @relation("FaqCategoryCreator", fields: [created_by], references: [user_id], onDelete: Restrict)
  updater    Admin?   @relation("FaqCategoryUpdater", fields: [updated_by], references: [user_id], onDelete: Restrict)

  items FaqItem[]

  @@index([position])
  @@map("faq_categories")
}

model FaqItem {
  id          String      @id @default(uuid())
  category_id String
  category    FaqCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  title       String
  content     String      @db.Text
  position    Int
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  created_by  String
  updated_by  String?
  creator     Admin       @relation("FaqItemCreator", fields: [created_by], references: [user_id], onDelete: Restrict)
  updater     Admin?      @relation("FaqItemUpdater", fields: [updated_by], references: [user_id], onDelete: Restrict)

  @@index([category_id, position])
  @@map("faq_items")
}
